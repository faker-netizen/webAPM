{
  "name": "@lxl_fe/webapm",
  "version": "1.0.4",
  "description": "A powerful front-end monitoring SDK for React and Vue applications",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/faker-netizen/webAPM.git"
  },
  "homepage": "https://github.com/faker-netizen/webAPM#readme",
  "bugs": {
    "url": "https://github.com/faker-netizen/webAPM/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:server": "node test-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "monitoring",
    "sdk",
    "frontend",
    "react",
    "vue",
    "error-tracking",
    "performance-monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "rrweb": "1.1.3",
    "source-map": "^0.7.4",
    "web-vitals": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.20.0",
    "@babel/preset-typescript": "^7.20.0",
    "@types/react": "^18.0.0",
    "@types/vue": "^2.0.0",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "cors": "^2.8.5",
    "eslint": "^8.0.0",
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
